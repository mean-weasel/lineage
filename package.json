{
  "name": "@mean-weasel/lineage",
  "version": "0.1.17",
  "description": "Local-first creative lineage workspace",
  "license": "MIT",
  "type": "module",
  "bin": {
    "lineage": "dist/cli/lineage.js",
    "lineage-channel": "dist/cli/lineage-channel.js",
    "lineage-dev": "dist/cli/lineage-dev.js",
    "lineage-preview": "dist/cli/lineage-preview.js",
    "lineage-service": "dist/cli/managed-service.js"
  },
  "files": [
    "dist",
    "fixtures/demo-project",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "NODE_ENV=development tsx src/server.ts",
    "lineage:dev": "tsx src/cli/lineage-dev.ts",
    "start": "NODE_ENV=production node dist/server.js",
    "build:web": "vite build --config vite.config.ts",
    "build:provenance": "node scripts/write-runtime-build.mjs",
    "build:server": "esbuild src/server.ts --bundle --platform=node --format=esm --target=node22 --packages=external --outfile=dist/server.js --sourcemap",
    "build:cli": "esbuild src/cli/lineage.ts src/cli/lineage-channel.ts src/cli/lineage-dev.ts src/cli/lineage-preview.ts --bundle --platform=node --format=esm --target=node22 --packages=external --outdir=dist/cli --sourcemap && esbuild scripts/managed-service.mjs --bundle --platform=node --format=esm --target=node22 --packages=external --outfile=dist/cli/managed-service.js --sourcemap",
    "build": "npm run build:web && npm run build:provenance && npm run build:server && npm run build:cli",
    "check": "tsc --noEmit",
    "lint": "eslint src scripts --max-warnings=0",
    "test": "NODE_OPTIONS=--no-warnings vitest run --config vitest.config.ts",
    "e2e": "node scripts/e2e-profile-runner.mjs",
    "knip": "knip",
    "audit": "npm audit --audit-level=moderate",
    "public:readiness": "node scripts/public-readiness.mjs",
    "package:smoke": "node scripts/package-smoke.mjs && node scripts/managed-service-smoke.mjs",
    "runtime:smoke": "node scripts/runtime-isolation-smoke.mjs",
    "runtime:oracle": "node scripts/coexistence-oracle.mjs",
    "onboarding:smoke": "node scripts/onboarding-smoke.mjs",
    "service": "node scripts/managed-service.mjs",
    "service:smoke": "node scripts/managed-service-smoke.mjs",
    "release:claim-smoke": "node scripts/release-claim-smoke.mjs",
    "seed:qa:prepare": "node scripts/qa-seed-verify.mjs --prepare",
    "seed:qa:verify": "node scripts/qa-seed-verify.mjs",
    "ci": "npm run check && npm run lint && npm run test && npm run knip && npm run build && npm run onboarding:smoke && npm run runtime:smoke && npm run runtime:oracle && npm run e2e && npm run public:readiness && npm run package:smoke && npm run plugin:smoke && npm run audit",
    "plugin:pack": "node scripts/plugin-release.mjs --out-dir dist/lineage-plugin --json",
    "plugin:smoke": "node scripts/plugin-release.mjs && npm test --prefix packages/lineage-plugin-installer && npm run check --prefix packages/lineage-plugin-installer",
    "plugin:codex-smoke": "node packages/lineage-plugin-installer/scripts/codex-smoke.mjs",
    "prepare-release": "node scripts/prepare-release.mjs",
    "release": "node scripts/release.mjs",
    "release:dry-run": "node scripts/release.mjs --dry-run",
    "release:next": "node scripts/release.mjs --tag next",
    "release:latest": "node scripts/release.mjs --tag latest",
    "release:promote-latest": "node scripts/release.mjs --promote-latest",
    "release:github": "node scripts/sync-github-release.mjs --channel latest",
    "release:github:next": "node scripts/sync-github-release.mjs --channel next",
    "release:github:dry-run": "node scripts/sync-github-release.mjs --channel latest --dry-run",
    "release:github:next:dry-run": "node scripts/sync-github-release.mjs --channel next --dry-run",
    "release:status": "node scripts/release-status.mjs"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@xyflow/react": "^12.11.1",
    "express": "^4.19.2",
    "lucide-react": "^0.468.0",
    "multer": "^2.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.2",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "knip": "^6.17.1",
    "playwright": "^1.61.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22.22.0"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/mean-weasel/lineage.git"
  },
  "bugs": {
    "url": "https://github.com/mean-weasel/lineage/issues"
  },
  "homepage": "https://github.com/mean-weasel/lineage#readme",
  "publishConfig": {
    "access": "public"
  }
}
